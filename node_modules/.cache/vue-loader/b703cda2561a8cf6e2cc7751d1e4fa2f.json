{"remainingRequest":"/home/octavio/aramar/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/octavio/aramar/src/components/Questions/Questions.vue?vue&type=script&lang=js&","dependencies":[{"path":"/home/octavio/aramar/src/components/Questions/Questions.vue","mtime":1584671460122},{"path":"/home/octavio/aramar/node_modules/babel-loader/lib/index.js","mtime":499162500000},{"path":"/home/octavio/aramar/node_modules/vuetify-loader/lib/loader.js","mtime":1574476662000},{"path":"/home/octavio/aramar/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/octavio/aramar/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Questions.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAmFA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Questions.vue","sourceRoot":"src/components/Questions","sourcesContent":["<template>\n  <div>\n    <v-overlay :value=\"loading\">\n      <v-progress-circular indeterminate size=\"64\"></v-progress-circular>\n    </v-overlay>\n    <v-container>\n      <v-container>\n          <v-container>\n            <v-text-field\n              v-model=\"search\"\n              filled\n              rounded\n              dense\n              append-icon=\"mdi-magnify\"\n              label=\"Search for IQ\"\n              single-line\n              hide-details\n            ></v-text-field>\n          </v-container>\n      </v-container>\n\n      <v-container>\n        <v-card>\n          <v-data-table\n            :headers=\"headers\"\n            :items=\"questions\"\n            :page.sync=\"page\"\n            :items-per-page=\"itemsPerPage\"\n            :search=\"search\"\n            hide-default-footer\n            class=\"elevation-1\"\n            @page-count=\"pageCount = $event\"\n          >\n            <template v-slot:item.actions=\"{ item }\">\n              <v-row justify=\"end\">\n                <router-link class=\"mr-6\" style=\"text-decoration: none;\" :to=\"{name:'printquestion', params:{questionId:item.id}}\" replace>\n                  <v-icon>mdi-pdf-box</v-icon>\n                </router-link>\n                <v-icon class=\"mr-2\" @click=\"editQuestions(item)\">mdi-pencil</v-icon>\n                <v-icon @click=\"deleteQuestionSnackBar = true; deleteSelect = item\" class=\"mr-2\">mdi-delete</v-icon>\n              </v-row>\n            </template>\n          </v-data-table>\n        </v-card>\n      </v-container>\n\n\n\n      <v-tooltip left>\n        <template v-slot:activator=\"{ on }\">\n          <v-btn v-on=\"on\" fixed dark fab bottom right color=\"cyan\" @click.stop=\"dialogNewQuestion= true\">\n            <v-icon>mdi-plus</v-icon>\n          </v-btn>\n        </template>\n        <span>Criar Questão</span>\n      </v-tooltip>\n\n      <v-dialog fullscreen hide-overlay transition=\"dialog-bottom-transition\" v-model=\"dialogNewQuestion\">\n        <Stepper  @closeDialogNew=\"dialogNewQuestion = false\" @load=\"setLoader()\"></Stepper>\n      </v-dialog>\n\n      <v-dialog fullscreen hide-overlay transition=\"dialog-bottom-transition\" v-model=\"dialogEditQuestion\">\n        <EditQuestion :question=\"selectedEdit\" @closeDialogEdit=\"dialogEditQuestion = false\" @load=\"setLoader()\"></EditQuestion>\n      </v-dialog>\n\n      <v-dialog fullscreen hide-overlay transition=\"dialog-bottom-transition\" v-model=\"dialogPDF\">\n        <Body :question=\"selectedEdit\" @closeDialogPrint=\"dialogPDF = false\"></Body>\n      </v-dialog>\n\n      <div class=\"text-center pt-2\">\n        <v-pagination v-model=\"page\" :length=\"pageCount\"></v-pagination>\n      </div>\n\n      <v-snackbar v-model=\"deleteQuestionSnackBar\" color=\"black\" right top>\n        Você realmente quer deletar esta questão?\n        <v-btn dark color=\"yellow\" text @click=\"deleteQuestion(deleteSelect.id)\">Ok</v-btn>\n        <v-btn dark color=\"yellow\" text @click=\"deleteQuestionSnackBar = false\">Cancelar</v-btn>\n      </v-snackbar>\n    </v-container>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      deleteSelect: \"\",\n      selectedEdit: {},\n      deleteQuestionSnackBar: false,\n      selected: [],\n      dialogNewQuestion: false,\n      dialogEditQuestion: false,\n      dialogPDF: false,\n      items: [\n        \"Teoria do Reator\",\n        \"Termodinâmica\",\n        \"Instrumentação e Controle\",\n        \"Válvulas e Bombas\",\n        \"Eletricidade\",\n        \"Mecânica dos Fluidos\",\n        \"Tratamento Qúimico Refrigerante\",\n        \"Análise Integrada\",\n        \"Instrumentação Nuclear\",\n        \"Física Nuclear\",\n        \"Transferência de Calor\",\n        \"Materiais\"\n      ],\n      showedQuestions: [],\n      search: \"\",\n      page: 1,\n      pageCount: 15,\n      itemsPerPage: 10,\n      headers: [\n        { text: \"IQ\", align: \"left\", sortable: false, value: \"id\" },\n        { text: \"Conhecimento\", value: \"data.CONHECIMENTO\" },\n        { text: \"Relevância OR\", value: \"data.RELEVANCIA_OR\" },\n        { text: \"Relevância OSR\", value: \"data.RELEVANCIA_OSR\" },\n        { text: \"Disciplina\", value: \"data.DISCIPLINA\", sortable: false },\n        { text: \"Ações\", align:\"right\", value: \"actions\", sortable: false }\n      ]\n    };\n  },\n  computed: {\n    loading () {\n        return this.$store.getters.loading\n        this.$store.dispatch('clearLoading')\n    },\n    questions() {\n      return this.$store.getters.loadedQuestions;\n    }\n  },\n  watch: {\n    selected(val) {\n      this.questions.forEach(element => {\n        for (let i = 0; i < this.selected.length; i++) {\n          if (element.data.DISCIPLINA == this.selected[i]) {\n            let aux = true;\n            for (let k = 0; k < this.showedQuestions.length; k++) {\n              if (element === this.showedQuestions[k]) aux = false;\n            }\n            if (aux == true) this.showedQuestions.push(element);\n          }\n        }\n      });\n    }\n  },\n  methods: {\n    editQuestions(val){\n      this.selectedEdit = val\n      this.loadQuestions()\n      this.dialogEditQuestion = true\n    },\n    generatePDF(val){\n      this.selectedEdit = val\n      this.dialogPDF = true\n    },\n    loadQuestions() {\n      console.log(\"é mano\")\n      let aux = this.$store.dispatch(\"loadedQuestions\");\n      aux.then(()=>{\n        return aux\n      })\n    },\n    removeSelections(i) {\n      let aux = this.showedQuestions.length;\n\n      for (let j = 0; j < aux; j++) {\n        if (this.showedQuestions[j].data.DISCIPLINA == this.selected[i]) {\n          this.showedQuestions.splice(j, 1);\n          j--;\n          aux--;\n        }\n      }\n\n      this.selected.splice(i, 1);\n    },\n    setLoader(){\n      this.loadQuestions()\n    },\n    selections(i) {\n      let aux = false;\n      for (let j = 0; j < this.selected.length; j++) {\n        if (this.items[i] == this.selected[j]) aux = true;\n      }\n\n      if (aux == false) this.selected.push(this.items[i]);\n    },\n    deleteQuestion(id) {\n      console.log(id);\n      let aux = this.$store.dispatch(\"deleteQuestion\", id);\n      aux.then(()=>{\n        this.deleteQuestionSnackBar = false;\n        this.loadQuestions();\n      })\n    }\n  }\n};\n</script>\n"]}]}