data.IMAGENS\" style=\"max-height: 250px; max-width: 180px\"/>\n      </div>\n\n      <v-content v-if=\"typeof question.data.RESPOSTAS[0].text !== 'string'\">\n        <v-row>\n          <v-col cols=\"2\"></v-col>\n          <v-col v-for=\"(item, index) in question.data.RESPOSTAS[0].text\" :key=\"index\" cols=\"2\">\n            <vue-markdown :source=\"item.title\"/>\n          </v-col>\n        </v-row>\n\n        <v-row>\n          <v-col cols=\"2\">A -</v-col>\n          <v-col\n            v-for=\"(item, index) in question.data.RESPOSTAS[0].text\"\n            :key=\"index\"\n            cols=\"2\"\n          >\n            <vue-markdown :source=\"item.answerDescription\"/>\n          </v-col>\n        </v-row>\n\n        <v-row>\n          <v-col cols=\"2\">B -</v-col>\n          <v-col\n            v-for=\"(item, index) in question.data.RESPOSTAS[1].text\"\n            :key=\"index\"\n            cols=\"2\"\n            >\n              <vue-markdown :source=\"item.answerDescription\"/>\n            </v-col>\n        </v-row>\n\n        <v-row>\n          <v-col cols=\"2\">C -</v-col>\n          <v-col\n            v-for=\"(item, index) in question.data.RESPOSTAS[2].text\"\n            :key=\"index\"\n            cols=\"2\"\n            >\n              <vue-markdown :source=\"item.answerDescription\"/>\n            </v-col>\n        </v-row>\n\n        <v-row>\n          <v-col cols=\"2\">D -</v-col>\n          <v-col\n            v-for=\"(item, index) in question.data.RESPOSTAS[3].text\"\n            :key=\"index\"\n            cols=\"2\"\n            >\n              <vue-markdown :source=\"item.answerDescription\"/>\n            </v-col>\n        </v-row>\n      </v-content>\n\n      <v-content v-else>\n        <v-row v-for=\"(item, index) in question.data.RESPOSTAS\" :key=\"index\">\n          <v-col cols=\"2\">{{ letters[index] }} - </v-col>\n          <v-col>\n            <vue-markdown :source=\"item.text\"/>\n          </v-col>\n        </v-row>\n      </v-content>\n\n      <v-btn class=\"buttonIsHidden\" fixed dark fab bottom right color=\"red\" @click=\"toPrint()\">\n        <v-icon>mdi-file-outline</v-icon>\n      </v-btn>\n\n      <v-btn\n        fixed\n        fab\n        bottom\n        left\n        class=\"buttonIsHidden\"\n        @click=\"back()\"\n      >\n        <v-icon>\n          mdi-arrow-left\n        </v-icon>\n      </v-btn>\n\n    </div>\n  </v-container>\n</template>\n\n<script>\nimport VueMarkdown from 'vue-markdown';\nrequire('vue-markdown');\n\nexport default {\n  components: {\n    'vue-markdown': VueMarkdown\n  },\n  data() {\n    return {\n      letters: ['A','B','C','D'],\n    }\n  },\n  computed: {\n    sla () {\n      console.log(\"mano: \",this.$route.params.questionId)\n      return this.$route.params.questionId\n    },\n    question () {\n      return this.$store.getters.findQuestionById(this.$route.params.questionId)\n    }\n  },\n  methods: {\n    back(){\n      this.$router.push('/questions');\n    },\n    toPrint() {\n      window.print()\n    },\n    confirmImage(val) {\n      if (typeof val == 'undefined' || val == \"\")\n        return false\n\n      else\n        return true\n    },\n    close() {\n      this.$emit(\"closeDialogPrint\")\n    }\n  }\n}\n</script>\n\n<style>\n@media print {\n   header{\n    display:none !important\n   }\n\n  @page {\n      margin-top: 2cm;\n      margin-bottom: 2cm;\n      margin-left: 2cm;\n      margin-right: 2cm;\n  }\n  .question-page {\n      page-break-after: always;\n  }\n\n  .buttonIsHidden {\n      visibility: hidden;\n  }\n\n  .img-container {\n      text-align: center !important;\n  }\n\n\n  p {\n    page-break-inside: avoid;\n  }\n}\n</style>\n"]}]}