{"remainingRequest":"/home/octavio/aramar/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/octavio/aramar/src/components/Documents/EditPaper.vue?vue&type=script&lang=js&","dependencies":[{"path":"/home/octavio/aramar/src/components/Documents/EditPaper.vue","mtime":1584501218436},{"path":"/home/octavio/aramar/node_modules/cache-loader/dist/cjs.js","mtime":1583758991757},{"path":"/home/octavio/aramar/node_modules/babel-loader/lib/index.js","mtime":1583758991013},{"path":"/home/octavio/aramar/node_modules/vuetify-loader/lib/loader.js","mtime":1583759007809},{"path":"/home/octavio/aramar/node_modules/cache-loader/dist/cjs.js","mtime":1583758991757},{"path":"/home/octavio/aramar/node_modules/vue-loader/lib/index.js","mtime":1583759007561}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["EditPaper.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAoDA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"EditPaper.vue","sourceRoot":"src/components/Documents","sourcesContent":["<template>\n  <v-card>\n    <v-form ref=\"formRef\" @submit.prevent=\"onEditPaper()\">\n      <v-toolbar dark color=\"primary\">\n        <v-btn icon dark @click=\"close()\">\n          <v-icon>mdi-close</v-icon>\n        </v-btn>\n        <v-spacer></v-spacer>\n          <v-btn dark text type=\"submit\">Edit Test</v-btn>\n        </v-toolbar-items>\n      </v-toolbar>\n      <v-container>\n        <v-row>\n          <v-col>\n            <v-card>\n              <v-container>\n                <v-row>\n                  <v-col>\n                      <v-file-input\n                        chips\n                        multiple\n                        dense\n                        label=\"Imagem\"\n                        v-model=\"images\"\n                      />\n                  </v-col>\n                </v-row>\n                <v-row>\n                  <v-col>\n                    <Combined :questionDescription=\"paperDescription\" @inputData=\"updateData\"></Combined>\n                  </v-col>\n                </v-row>\n              </v-container>\n            </v-card>\n          </v-col>\n          <v-col>\n            <v-card>\n              <v-card-title>Preview</v-card-title>\n              <v-card-subtitle>{{paperName}}</v-card-subtitle>\n              <v-row justify=\"center\">\n                <img v-if=\"hasImage\" :src=\"paperImage\" style=\"max-width: 400px\"></img>\n              </v-row>\n              <v-card-text>{{paperDescription}}</v-card-text>\n            </v-card>\n          </v-col>\n        </v-row>\n      </v-container>\n    </v-form>\n  </v-card>\n</template>\n\n<script>\nexport default {\n  props: [\"paper\"],\n\n  data: () => ({\n    paperDescription: \"\",\n    paperName: \"\",\n    images: [],\n    paperImage: \"\"\n  }),\n\n  computed: {\n    name(){\n      var aux = this.paper.data.name\n      this.paperName = aux\n      return aux\n    }\n  },\n\n  watch: {\n    paperName(){\n      this.paperName = this.paper.data.name\n      this.paperDescription = this.paper.data.description\n      this.paperImage = this.paper.data.image\n    }\n  },\n\n  methods: {\n    hasImage(){\n      if( paperImage !== '' && typeof paperImage !== 'undefined')\n        return true\n      else\n        return false\n    },\n    updateData(variable) {\n      this.paperDescription = variable;\n    },\n    close() {\n      this.setInitialData();\n      this.$emit(\"closeDialogEdit\");\n    },\n    setInitialData() {\n      this.paperDescription = null,\n      this.paperName = null,\n      this.paperImage = \"\",\n      this.image = []\n    },\n    onEditPaper() {\n      if((this.paperName === \"\" && this.paperDescription === \"\") || (this.paperName === \"\" && typeof this.images[0] === 'undefined')){\n        console.log(\"nop\");\n        return\n      }\n\n      if ( typeof this.images[0] !== 'undefined') {\n        const imageToUpload = {images: this.images[0]}\n        var URL = this.$store.dispatch(\"uploadImage\", imageToUpload)\n        URL.then(result => {\n          this.paperImage = result\n          console.log(\"Image as URL: \",this.paperImage)\n          const paperData = {\n            paperName: this.paperName,\n            paperDescription: this.paperDescription,\n            paperImage: this.paperImage,\n            id: this.paper.id\n          };\n\n          let aux = this.$store.dispatch(\"updatePaper\", paperData);\n          aux.then(()=>{\n            this.$emit(\"load\");\n            this.close();\n          })\n        })\n      }\n\n      else {\n        const paperData = {\n          paperName: this.paperName,\n          paperDescription: this.paperDescription,\n          paperImage: this.paperImage,\n          id: this.paper.id\n        };\n\n        let aux = this.$store.dispatch(\"updatePaper\", paperData);\n        aux.then(()=>{\n          this.$emit(\"load\");\n          this.close();\n        })\n      }\n    }\n  }\n}\n</script>\n"]}]}