{"remainingRequest":"/home/octavio/aramar/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/octavio/aramar/src/components/Documents/EditPaper.vue?vue&type=script&lang=js&","dependencies":[{"path":"/home/octavio/aramar/src/components/Documents/EditPaper.vue","mtime":1584675649672},{"path":"/home/octavio/aramar/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/octavio/aramar/node_modules/thread-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/octavio/aramar/node_modules/babel-loader/lib/index.js","mtime":499162500000},{"path":"/home/octavio/aramar/node_modules/vuetify-loader/lib/loader.js","mtime":1574476662000},{"path":"/home/octavio/aramar/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/octavio/aramar/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["EditPaper.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAmFA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"EditPaper.vue","sourceRoot":"src/components/Documents","sourcesContent":["<template>\n  <v-card>\n    <v-form ref=\"formRef\" @submit.prevent=\"onEditPaper()\">\n      <v-toolbar dark color=\"primary\">\n        <v-btn icon dark @click=\"close()\">\n          <v-icon>mdi-close</v-icon>\n        </v-btn>\n        <v-spacer></v-spacer>\n          <v-btn dark text type=\"submit\">Editar Documento</v-btn>\n        </v-toolbar-items>\n      </v-toolbar>\n      <v-container fluid>\n        <v-row>\n          <v-col>\n            <v-row>\n              <v-col>\n                <h1>Formulário</h1>\n              </v-col>\n            </v-row>\n            <v-row>\n              <v-col cols=\"12\">\n                <v-card>\n                  <v-container>\n                    <v-row>\n                      <v-col>\n                        <v-text-field\n                          solo\n                          flat\n                          filled\n                          outlined\n                          dense\n                          label=\"Paper name\"\n                          v-model=\"paperName\"\n                          required\n                        ></v-text-field>\n                      </v-col>\n                    </v-row>\n                    <v-row>\n                      <v-col>\n                          <v-file-input\n                            chips\n                            multiple\n                            dense\n                            label=\"Imagem\"\n                            v-model=\"images\"\n                          />\n                      </v-col>\n                    </v-row>\n                    <v-row>\n                      <v-col>\n                        <Combined :questionDescription=\"paperDescription\" @inputData=\"updateData\"></Combined>\n                      </v-col>\n                    </v-row>\n                  </v-container>\n                </v-card>\n              </v-col>\n            </v-row>\n          </v-col>\n          <v-col>\n            <v-row>\n              <v-col>\n                <h1>Preview</h1>\n              </v-col>\n            </v-row>\n            <v-row fill-width>\n              <v-col cols=\"12\">\n                <v-card>\n                  <v-card-title>{{name}}</v-card-title>\n                  <v-row justify=\"center\">\n                    <img v-if=\"hasImage\" :src=\"paperImage\" style=\"max-width: 400px\"></img>\n                  </v-row>\n                  <v-card-text>{{paperDescription}}</v-card-text>\n                </v-card>\n              </v-col>\n            </v-row>\n          </v-col>\n        </v-row>\n      </v-container>\n    </v-form>\n  </v-card>\n</template>\n\n<script>\nexport default {\n  props: [\"paper\"],\n\n  data: () => ({\n    paperDescription: \"\",\n    paperName: \"\",\n    images: [],\n    paperImage: \"\"\n  }),\n\n  computed: {\n    name(){\n      var aux = this.paper.data.name\n      this.paperName = aux\n      return aux\n    }\n  },\n\n  watch: {\n    paperName(){\n      this.update();\n    }\n  },\n\n  methods: {\n    update(){\n      this.paperDescription = this.paper.data.description\n      this.paperImage = this.paper.data.image\n    },\n    hasImage(){\n      if( paperImage !== '' && typeof paperImage !== 'undefined')\n        return true\n      else\n        return false\n    },\n    updateData(variable) {\n      this.paperDescription = variable;\n    },\n    close() {\n      this.setInitialData();\n      this.update();\n      this.$emit(\"closeDialogEdit\");\n    },\n    setInitialData() {\n      this.paperDescription = null,\n      this.paperName = null,\n      this.paperImage = \"\",\n      this.image = []\n    },\n    onEditPaper() {\n      if((this.paperName === \"\" && this.paperDescription === \"\") || (this.paperName === \"\" && typeof this.images[0] === 'undefined')){\n        console.log(\"nop\");\n        return\n      }\n\n      if ( typeof this.images[0] !== 'undefined') {\n        const imageToUpload = {images: this.images[0]}\n        var URL = this.$store.dispatch(\"uploadImage\", imageToUpload)\n        URL.then(result => {\n          this.paperImage = result\n          console.log(\"Image as URL: \",this.paperImage)\n          const paperData = {\n            paperName: this.paperName,\n            paperDescription: this.paperDescription,\n            paperImage: this.paperImage,\n            id: this.paper.id\n          };\n\n          let aux = this.$store.dispatch(\"updatePaper\", paperData);\n          aux.then(()=>{\n            this.$emit(\"load\");\n            this.close();\n          })\n        })\n      }\n\n      else {\n        console.log(\"paperName: \", this.paperName);\n        const paperData = {\n          paperName: this.paperName,\n          paperDescription: this.paperDescription,\n          paperImage: this.paperImage,\n          id: this.paper.id\n        };\n\n        let aux = this.$store.dispatch(\"updatePaper\", paperData);\n        aux.then(()=>{\n          this.$emit(\"load\");\n          this.close();\n        })\n      }\n    }\n  }\n}\n</script>\n"]}]}