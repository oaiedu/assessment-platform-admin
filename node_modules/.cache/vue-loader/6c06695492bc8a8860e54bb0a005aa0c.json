{"remainingRequest":"/home/octavio/aramar/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/octavio/aramar/src/components/Documents/Papers.vue?vue&type=script&lang=js&","dependencies":[{"path":"/home/octavio/aramar/src/components/Documents/Papers.vue","mtime":1584673583846},{"path":"/home/octavio/aramar/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/octavio/aramar/node_modules/babel-loader/lib/index.js","mtime":499162500000},{"path":"/home/octavio/aramar/node_modules/vuetify-loader/lib/loader.js","mtime":1574476662000},{"path":"/home/octavio/aramar/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/home/octavio/aramar/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Papers.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAyEA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Papers.vue","sourceRoot":"src/components/Documents","sourcesContent":["<template>\n  <div>\n    <v-overlay :value=\"loading\">\n      <v-progress-circular indeterminate size=\"64\"></v-progress-circular>\n    </v-overlay>\n    <v-container>\n      <v-container>\n          <v-container>\n            <v-text-field\n              v-model=\"search\"\n              filled\n              rounded\n              dense\n              append-icon=\"mdi-magnify\"\n              label=\"Search for IQ\"\n              single-line\n              hide-details\n            ></v-text-field>\n          </v-container>\n      </v-container>\n\n      <v-container>\n        <v-card>\n          <v-data-table\n            :headers=\"headers\"\n            :items=\"papers\"\n            :page.sync=\"page\"\n            :items-per-page=\"itemsPerPage\"\n            :search=\"search\"\n            hide-default-footer\n            class=\"elevation-1\"\n            @page-count=\"pageCount = $event\"\n          >\n            <template small v-slot:item.actions=\"{ item }\">\n              <v-row justify=\"end\">\n                <v-icon class=\"mr-2\" @click=\"editPaper(item)\">mdi-pencil</v-icon>\n                <v-icon @click=\"deletePaperSnackBar = true; deleteSelect = item\" class=\"mr-2\">mdi-delete</v-icon>\n              </v-row>\n            </template>\n          </v-data-table>\n        </v-card>\n      </v-container>\n      \n      <v-tooltip left>\n        <template v-slot:activator=\"{ on }\">\n          <v-btn v-on=\"on\" fixed dark fab bottom right color=\"cyan\" @click.stop=\"dialogNewPaper = true\">\n            <v-icon>mdi-plus</v-icon>\n          </v-btn>\n        </template>\n        <span>Criar Questão</span>\n      </v-tooltip>\n\n      <v-dialog fullscreen hide-overlay transition=\"dialog-bottom-transition\" v-model=\"dialogNewPaper\">\n        <NewPaper @closeDialogNew=\"dialogNewPaper = false\"></NewPaper>\n      </v-dialog>\n\n      <v-dialog fullscreen hide-overlay transition=\"dialog-bottom-transition\" v-model=\"dialogEditPaper\">\n        <EditPaper :paper=\"selectedEdit\" @closeDialogEdit=\"dialogEditPaper = false\"></EditPaper>\n      </v-dialog>\n\n      <div class=\"text-center pt-2\">\n        <v-pagination v-model=\"page\" :length=\"pageCount\"></v-pagination>\n      </div>\n      <v-snackbar v-model=\"deletePaperSnackBar\" color=\"black\" right top>\n        Você realmente quer deletar esta prova?\n        <v-btn dark color=\"yellow\" text @click=\"deletePaper(deleteSelect.id)\">Ok</v-btn>\n        <v-btn dark color=\"yellow\" text @click=\"deletePaperSnackBar = false\">Cancelar</v-btn>\n      </v-snackbar>\n    </v-container>\n  </div>\n</template>\n\n<script>\nimport NewPaper from './CreatePaper'\nimport EditPaper from './EditPaper'\n\nexport default {\n  components: {\n    NewPaper,\n    EditPaper\n  },\n  data: () => ({\n    dialogNewPaper: false,\n    dialogEditPaper: false,\n    selectedEdit: {},\n    headers: [\n      { text: \"Nome\", align: \"left\",  value: \"data.name\" },\n      { text: \"Ações\", align:\"right\", value: \"actions\", sortable: false }\n    ],\n    page: 1,\n    pageCount: 15,\n    itemsPerPage: 10,\n    search: \"\",\n    deletePaperSnackBar: false,\n    deleteSelect: \"\",\n  }),\n  computed: {\n    loading () {\n        return this.$store.getters.loading\n        this.$store.dispatch('clearLoading')\n    },\n    papers () {\n      return this.$store.getters.loadedPapers\n    }\n  },\n  methods: {\n    editPaper(val){\n      this.selectedEdit = val;\n      this.loadPapers();\n      this.dialogEditPaper = true;\n    },\n    loadPapers() {\n      console.log(\"é mano\")\n      let aux = this.$store.dispatch(\"loadedPapers\");\n      aux.then(()=>{\n        return aux\n      })\n    },\n    setLoader(){\n      this.loadQuestions()\n    },\n    deletePaper(id) {\n      console.log(id);\n      let aux = this.$store.dispatch(\"deletePaper\", id);\n      aux.then(()=>{\n        this.deletePaperSnackBar = false;\n        this.loadPapers();\n      })\n    }\n  }\n}\n</script>\n"]}]}