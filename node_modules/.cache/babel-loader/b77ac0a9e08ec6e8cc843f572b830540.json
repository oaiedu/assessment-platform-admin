{"remainingRequest":"/home/octavio/aramar/node_modules/babel-loader/lib/index.js!/home/octavio/aramar/node_modules/vuetify-loader/lib/loader.js??ref--17-0!/home/octavio/aramar/node_modules/cache-loader/dist/cjs.js??ref--0-0!/home/octavio/aramar/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/octavio/aramar/src/components/Questions/PrintQuestion/Body.vue?vue&type=script&lang=js&","dependencies":[{"path":"/home/octavio/aramar/src/components/Questions/PrintQuestion/Body.vue","mtime":1587190248169},{"path":"/home/octavio/aramar/node_modules/cache-loader/dist/cjs.js","mtime":1586898361385},{"path":"/home/octavio/aramar/node_modules/babel-loader/lib/index.js","mtime":1586898361181},{"path":"/home/octavio/aramar/node_modules/vuetify-loader/lib/loader.js","mtime":1586898367345},{"path":"/home/octavio/aramar/node_modules/cache-loader/dist/cjs.js","mtime":1586898361385},{"path":"/home/octavio/aramar/node_modules/vue-loader/lib/index.js","mtime":1586898367277}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Body.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA4GA,OAAA,WAAA,MAAA,cAAA;;AACA,OAAA,CAAA,cAAA,CAAA;;AAEA,eAAA;AACA,EAAA,KAAA,EAAA,CAAA,UAAA,CADA;AAEA,EAAA,UAAA,EAAA;AACA,oBAAA;AADA,GAFA;AAKA,EAAA,IALA,kBAKA;AACA,WAAA;AACA,MAAA,OAAA,EAAA,CAAA,GAAA,EAAA,GAAA,EAAA,GAAA,EAAA,GAAA;AADA,KAAA;AAGA,GATA;AAUA,EAAA,OAAA,EAAA;AACA,IAAA,IADA,kBACA;AACA,WAAA,KAAA,CAAA,kBAAA;AACA,KAHA;AAIA,IAAA,OAJA,qBAIA;AACA,MAAA,MAAA,CAAA,KAAA;AACA,KANA;AAOA,IAAA,YAPA,wBAOA,GAPA,EAOA;AACA,UAAA,OAAA,GAAA,IAAA,WAAA,IAAA,GAAA,IAAA,EAAA,EACA,OAAA,KAAA,CADA,KAIA,OAAA,IAAA;AACA,KAbA;AAcA,IAAA,KAdA,mBAcA;AACA,WAAA,KAAA,CAAA,kBAAA;AACA;AAhBA;AAVA,CAAA","sourcesContent":["<template>\n  <div class=\"print\">\n    <v-container>\n      <link rel=\"stylesheet\" href=\"https://unpkg.com/katex@0.6.0/dist/katex.min.css\">\n      <div class=\"question-page\">\n        DISCIPLINA: {{ question.data.DISCIPLINA }}\n        <br>\n\n        CONHECIMENTO: {{ question.data.CONHECIMENTO }} [ {{ question.data.RELEVANCIA_OR }} / {{ question.data.RELEVANCIA_OSR }} ]\n        <br>\n\n        IQ: {{ question.id }}\n        <br>\n\n        <br>\n          <vue-markdown :source=\"question.data.PERGUNTA\"/>\n        <br>\n\n        <br>\n\n        <div class=\"img-container\" v-if=\"confirmImage(question.data.IMAGENS)\">\n          <img :src=\"question.data.IMAGENS\" style=\"max-height: 250px; max-width: 180px\"/>\n        </div>\n\n        <v-content v-if=\"typeof question.data.RESPOSTAS[0].text !== 'string'\">\n          <v-row>\n            <v-col cols=\"2\"></v-col>\n            <v-col v-for=\"(item, index) in question.data.RESPOSTAS[0].text\" :key=\"index\" cols=\"2\">\n              <vue-markdown :source=\"item.title\"/>\n            </v-col>\n          </v-row>\n\n          <v-row>\n            <v-col cols=\"2\">A -</v-col>\n            <v-col\n              v-for=\"(item, index) in question.data.RESPOSTAS[0].text\"\n              :key=\"index\"\n              cols=\"2\"\n            >\n              <vue-markdown :source=\"item.answerDescription\"/>\n            </v-col>\n          </v-row>\n\n          <v-row>\n            <v-col cols=\"2\">B -</v-col>\n            <v-col\n              v-for=\"(item, index) in question.data.RESPOSTAS[1].text\"\n              :key=\"index\"\n              cols=\"2\"\n              >\n                <vue-markdown :source=\"item.answerDescription\"/>\n              </v-col>\n          </v-row>\n\n          <v-row>\n            <v-col cols=\"2\">C -</v-col>\n            <v-col\n              v-for=\"(item, index) in question.data.RESPOSTAS[2].text\"\n              :key=\"index\"\n              cols=\"2\"\n              >\n                <vue-markdown :source=\"item.answerDescription\"/>\n              </v-col>\n          </v-row>\n\n          <v-row>\n            <v-col cols=\"2\">D -</v-col>\n            <v-col\n              v-for=\"(item, index) in question.data.RESPOSTAS[3].text\"\n              :key=\"index\"\n              cols=\"2\"\n              >\n                <vue-markdown :source=\"item.answerDescription\"/>\n              </v-col>\n          </v-row>\n        </v-content>\n\n        <v-content v-else>\n          <v-row v-for=\"(item, index) in question.data.RESPOSTAS\" :key=\"index\">\n            <v-col cols=\"2\">{{ letters[index] }} - </v-col>\n            <v-col>\n              <vue-markdown :source=\"item.text\"/>\n            </v-col>\n          </v-row>\n        </v-content>\n\n        <v-btn class=\"buttonIsHidden\" fixed dark fab bottom right color=\"red\" @click=\"toPrint()\">\n          <v-icon>mdi-file-outline</v-icon>\n        </v-btn>\n\n        <v-btn\n          fixed\n          fab\n          bottom\n          left\n          class=\"buttonIsHidden\"\n          @click=\"back()\"\n        >\n          <v-icon>\n            mdi-arrow-left\n          </v-icon>\n        </v-btn>\n      </div>\n    </v-container>\n  </div>\n</template>\n\n<script>\nimport VueMarkdown from 'vue-markdown';\nrequire('vue-markdown');\n\nexport default {\n  props: [\"question\"],\n  components: {\n    'vue-markdown': VueMarkdown\n  },\n  data() {\n    return {\n      letters: ['A','B','C','D'],\n    }\n  },\n  methods: {\n    back(){\n      this.$emit(\"closeDialogPrint\");\n    },\n    toPrint() {\n      window.print()\n    },\n    confirmImage(val) {\n      if (typeof val == 'undefined' || val == \"\")\n        return false\n\n      else\n        return true\n    },\n    close() {\n      this.$emit(\"closeDialogPrint\")\n    }\n  }\n}\n</script>\n\n<style>\n.print {\n    background-color: white;\n    height: 100%;\n    width: 100%;\n    position: fixed;\n    display: block;\n    top: 0;\n    left: 0;\n    margin: 0;\n    padding: 15px;\n    font-size: 14px;\n    line-height: 18px;\n}\n@media print {\n   header{\n    display:none !important\n   }\n  @page {\n      margin-top: 2cm;\n      margin-bottom: 2cm;\n      margin-left: 2cm;\n      margin-right: 2cm;\n  }\n  .question-page {\n      page-break-after: always;\n  }\n\n  .buttonIsHidden {\n      visibility: hidden;\n  }\n\n  .img-container {\n      text-align: center !important;\n  }\n\n\n  p {\n    page-break-inside: avoid;\n  }\n}\n</style>\n"],"sourceRoot":"src/components/Questions/PrintQuestion"}]}