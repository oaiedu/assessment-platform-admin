AEA,UAAA,OAAA,CAAA,KAAA,GAAA,KAAA;AACA;AACA,OAZA;AAaA;AA5CA,GA3DA;AAyGA,EAAA,OAAA,EAAA;AACA,IAAA,eADA,6BACA;AACA,UAAA,KAAA,MAAA,GAAA,CAAA,EAAA,KAAA,MAAA;AACA,KAHA;AAIA,IAAA,eAJA,6BAIA;AACA,UAAA,KAAA,MAAA,GAAA,CAAA,EAAA,KAAA,MAAA;AACA,KANA;AAOA,IAAA,UAPA,sBAOA,QAPA,EAOA;AACA,WAAA,mBAAA,GAAA,QAAA;AACA,KATA;AAUA,IAAA,gBAVA,8BAUA;AAAA;;AACA,MAAA,OAAA,CAAA,GAAA,CAAA,SAAA,EAAA,KAAA,OAAA,CAAA,CAAA,EAAA,KAAA;;AAEA,UAAA,OAAA,KAAA,MAAA,CAAA,CAAA,CAAA,KAAA,WAAA,EAAA;AACA,YAAA,aAAA,GAAA;AAAA,UAAA,MAAA,EAAA,KAAA,MAAA,CAAA,CAAA;AAAA,SAAA;AACA,YAAA,GAAA,GAAA,KAAA,MAAA,CAAA,QAAA,CAAA,aAAA,EAAA,aAAA,CAAA;AACA,QAAA,GAAA,CAAA,IAAA,CAAA,UAAA,MAAA,EAAA;AACA,UAAA,MAAA,CAAA,WAAA,GAAA,MAAA;AACA,UAAA,OAAA,CAAA,GAAA,CAAA,gBAAA,EAAA,MAAA,CAAA,WAAA;AACA,cAAA,YAAA,GAAA;AACA,YAAA,EAAA,EAAA,MAAA,CAAA,EADA;AAEA,YAAA,OAAA,EAAA,MAAA,CAAA,OAFA;AAGA,YAAA,mBAAA,EAAA,MAAA,CAAA,mBAHA;AAIA,YAAA,SAAA,EAAA,MAAA,CAAA,SAJA;AAKA,YAAA,YAAA,EAAA,MAAA,CAAA,YALA;AAMA,YAAA,YAAA,EAAA,MAAA,CAAA,YANA;AAOA,YAAA,OAAA,EAAA,MAAA,CAAA,OAPA;AAQA,YAAA,MAAA,EAAA,MAAA,CAAA;AARA,WAAA;;AAWA,cAAA,GAAA,GAAA,MAAA,CAAA,MAAA,CAAA,QAAA,CAAA,gBAAA,EAAA,YAAA,CAAA;;AACA,UAAA,GAAA,CAAA,IAAA,CAAA,YAAA;AACA,YAAA,MAAA,CAAA,cAAA;;AACA,YAAA,MAAA,CAAA,KAAA;AACA,WAHA;AAIA,SAnBA;AAoBA,OAvBA,MAyBA;AACA,YAAA,YAAA,GAAA;AACA,UAAA,EAAA,EAAA,KAAA,EADA;AAEA,UAAA,OAAA,EAAA,KAAA,OAFA;AAGA,UAAA,mBAAA,EAAA,KAAA,mBAHA;AAIA,UAAA,SAAA,EAAA,KAAA,SAJA;AAKA,UAAA,YAAA,EAAA,KAAA,YALA;AAMA,UAAA,YAAA,EAAA,KAAA,YANA;AAOA,UAAA,OAAA,EAAA,KAAA,OAPA;AAQA,UAAA,MAAA,EAAA;AARA,SAAA;AAWA,YAAA,GAAA,GAAA,KAAA,MAAA,CAAA,QAAA,CAAA,gBAAA,EAAA,YAAA,CAAA;AACA,QAAA,GAAA,CAAA,IAAA,CAAA,YAAA;AACA,UAAA,MAAA,CAAA,cAAA;;AACA,UAAA,MAAA,CAAA,KAAA;AACA,SAHA;AAIA;AACA,KAxDA;AAyDA,IAAA,cAzDA,4BAyDA;AACA,WAAA,YAAA,GAAA,KAAA;AACA,WAAA,mBAAA,GAAA,EAAA;AACA,WAAA,EAAA,GAAA,CAAA;AACA,WAAA,IAAA,GAAA,IAAA;AACA,WAAA,OAAA,GAAA,IAAA;AACA,WAAA,MAAA,GAAA,MAAA;AACA,WAAA,cAAA,GAAA,KAAA;AACA,WAAA,QAAA,GAAA,EAAA;AACA,WAAA,KAAA,GAAA,EAAA;AACA,WAAA,KAAA,GAAA,EAAA;AACA,WAAA,OAAA,GAAA,CACA;AAAA,QAAA,IAAA,EAAA,EAAA;AAAA,QAAA,KAAA,EAAA,SAAA;AAAA,QAAA,KAAA,EAAA;AAAA,OADA,EAEA;AAAA,QAAA,IAAA,EAAA,EAAA;AAAA,QAAA,KAAA,EAAA,SAAA;AAAA,QAAA,KAAA,EAAA;AAAA,OAFA,EAGA;AAAA,QAAA,IAAA,EAAA,EAAA;AAAA,QAAA,KAAA,EAAA,SAAA;AAAA,QAAA,KAAA,EAAA;AAAA,OAHA,EAIA;AAAA,QAAA,IAAA,EAAA,EAAA;AAAA,QAAA,KAAA,EAAA,SAAA;AAAA,QAAA,KAAA,EAAA;AAAA,OAJA,CAAA;AAMA,WAAA,EAAA,GAAA,EAAA;AACA,WAAA,OAAA,GAAA,EAAA;AACA,WAAA,SAAA,GAAA,EAAA;AACA,WAAA,YAAA,GAAA,EAAA;AACA,WAAA,YAAA,GAAA,EAAA;AACA,WAAA,YAAA,GAAA,CACA,kBADA,EAEA,eAFA,EAGA,2BAHA,EAIA,mBAJA,EAKA,cALA,EAMA,sBANA,EAOA,iCAPA,EAQA,mBARA,EASA,wBATA,EAUA,gBAVA,EAWA,wBAXA,EAYA,WAZA,CAAA;AAcA,WAAA,MAAA,GAAA,CAAA;AACA,WAAA,MAAA,GAAA,EAAA;AACA,WAAA,cAAA,GAAA,EAAA;AACA,KAhGA;AAiGA,IAAA,KAjGA,mBAiGA;AACA,WAAA,cAAA;AACA,WAAA,KAAA,CAAA,gBAAA;AACA;AApGA;AAzGA,CAAA","sourcesContent":["<template>\n  <v-card>\n    <link rel=\"stylesheet\" href=\"https://unpkg.com/katex@0.6.0/dist/katex.min.css\">\n    <v-toolbar dark color=\"primary\">\n      <v-btn icon dark @click=\"close()\">\n        <v-icon>mdi-close</v-icon>\n      </v-btn>\n      <v-spacer></v-spacer>\n      <v-toolbar-items>\n        <v-btn dark text @click=\"e1 = 2\" v-if=\"e1 == 1\">Continue</v-btn>\n        <v-btn dark text @click=\"e1 = 3\" v-if=\"e1 == 2\">Continue</v-btn>\n        <v-btn dark text @click=\"onCreateQuestion()\" v-if=\"e1 == 3\">Criar Questão</v-btn>\n      </v-toolbar-items>\n    </v-toolbar>\n    <v-container fluid>\n      <v-row>\n        <v-col>\n          <v-card>\n            <form @submit.prevent=\"onCreateQuestion\">\n              <v-stepper v-model=\"e1\">\n                <v-stepper-header>\n                  <v-stepper-step editable :complete=\"e1 > 1\" step=\"1\"></v-stepper-step>\n\n                  <v-divider></v-divider>\n\n                  <v-stepper-step editable :complete=\"e1 > 2\" step=\"2\"></v-stepper-step>\n\n                  <v-divider></v-divider>\n\n                  <v-stepper-step editable step=\"3\"></v-stepper-step>\n                </v-stepper-header>\n\n                <v-stepper-items>\n                  <v-stepper-content step=\"1\">\n                    <v-container>\n                      <v-row>\n                        <v-text-field name=\"id\" label=\"IQ\" id=\"id\" v-model=\"id\" required></v-text-field>\n                      </v-row>\n\n                      <v-row>\n                        <v-text-field\n                          name=\"knowledge\"\n                          label=\"Conhecimento\"\n                          id=\"knowledge\"\n                          v-model=\"knowledge\"\n                          required\n                        ></v-text-field>\n                      </v-row>\n\n                      <v-row>\n                        <v-text-field\n                          name=\"knowledgePWR\"\n                          label=\"Relevância OR\"\n                          id=\"knowledgePWR\"\n                          v-model=\"knowledgePWR\"\n                          required\n                        ></v-text-field>\n                      </v-row>\n\n                      <v-row>\n                        <v-text-field\n                          name=\"knowledgeBWR\"\n                          label=\"Relevância OSR\"\n                          id=\"knowledgeBWR\"\n                          v-model=\"knowledgeBWR\"\n                          required\n                        ></v-text-field>\n                      </v-row>\n\n                      <v-row>\n                        <v-select\n                          :items=\"subjectItems\"\n                          name=\"subject\"\n                          id=\"subject\"\n                          v-model=\"subject\"\n                          label=\"Disciplina\"\n                          solo\n                        ></v-select>\n                      </v-row>\n                    </v-container>\n                  </v-stepper-content>\n\n                  <v-stepper-content step=\"2\">\n                    <v-container>\n                      <v-row>\n                        <editor v-model=\"questionDescription\"/>\n                      </v-row>\n                      <v-row>\n                        <v-file-input\n                          chips\n                          multiple\n                          label=\"Imagem\"\n                          v-model=\"images\"\n                        />\n                      </v-row>\n                    </v-container>\n                  </v-stepper-content>\n\n                  <v-stepper-content step=\"3\">\n                    <v-container>\n                      <v-row>\n                        <v-container>\n                          Colunas\n                          <v-btn\n                            @click=\"increaseColumns\"\n                            class=\"mx-2\"\n                            fab\n                            dark\n                            x-small\n                            color=\"primary\"\n                          >\n                            <v-icon dark>mdi-plus</v-icon>\n                          </v-btn>\n\n                          <v-btn\n                            @click=\"decreaseColumns\"\n                            class=\"mx-2\"\n                            fab\n                            dark\n                            x-small\n                            color=\"primary\"\n                          >\n                            <v-icon dark>mdi-minus</v-icon>\n                          </v-btn>\n                        </v-container>\n                      </v-row>\n\n                      <v-content v-if=\"confirmTitle\">\n                        <v-row justify=\"end\">\n                          <v-col cols=\"1\"></v-col>\n                          <v-col v-for=\"i in number\" :key=\"i\">\n                            <v-text-field outlined v-model=\"auxTitle[i-1]\"></v-text-field>\n                          </v-col>\n                        </v-row>\n                        <v-row v-for=\"(item, index) in answers\" :key=\"index\">\n                          <v-col cols=\"12\" md=\"1\" sm=\"1\" xs=\"1\">\n                            <v-radio-group v-model=\"radios\">\n                              <v-radio :value=\"item.ansId\"></v-radio>\n                            </v-radio-group>\n                          </v-col>\n                          <v-col v-for=\"(answerItem, index) in item.text\" :key=\"index\">\n                            <v-text-field outlined v-model=\"answerItem.answerDescription\"></v-text-field>\n                          </v-col>\n                        </v-row>\n                      </v-content>\n\n                      <v-content v-else>\n                        <v-row v-for=\"(item, index) in answers\" :key=\"index\">\n\n                          <v-col cols=\"12\" md=\"1\" sm=\"1\" xs=\"1\">\n                            <v-radio-group v-model=\"radios\">\n                              <v-radio :value=\"item.ansId\"></v-radio>\n                            </v-radio-group>\n                          </v-col>\n                          <v-col>\n                            <v-text-field outlined v-model=\"item.text\"></v-text-field>\n                          </v-col>\n                        </v-row>\n                      </v-content>\n\n                    </v-container>\n                  </v-stepper-content>\n                </v-stepper-items>\n              </v-stepper>\n            </form>\n          </v-card>\n        </v-col>\n\n        <v-col>\n          <v-card fill>\n            <v-card-title>Preview</v-card-title>\n            <v-card-text>\n              DISCIPLINA: {{subject}}\n              <br />\n              CONHECIMENTO: {{knowledge}} [{{knowledgePWR}}/{{knowledgeBWR}}]\n              <br />\n              IQ: {{id}}\n              <br />\n\n              <br/>\n                <vue-markdown :source=\"questionDescription\"/>\n              <br/>\n\n              <v-content v-if=\"confirmTitle\">\n                <v-row>\n                  <v-col cols=\"2\"></v-col>\n                  <v-col v-for=\"(item, index) in answers[0].text\" :key=\"index\" cols=\"2\">\n                    <vue-markdown :source=\"item.title\"/>\n                  </v-col>\n                </v-row>\n\n                <v-row>\n                  <v-col cols=\"2\">A -</v-col>\n                  <v-col\n                    v-for=\"(item, index) in answers[0].text\"\n                    :key=\"index\"\n                    cols=\"2\"\n                  >\n                    <vue-markdown :source=\"item.answerDescription\"/>\n                  </v-col>\n                </v-row>\n                <br />\n\n                <v-row>\n                  <v-col cols=\"2\">B -</v-col>\n                  <v-col\n                    v-for=\"(item, index) in answers[1].text\"\n                    :key=\"index\"\n                    cols=\"2\"\n                    >\n                      <vue-markdown :source=\"item.answerDescription\"/>\n                    </v-col>\n                </v-row>\n                <br />\n\n                <v-row>\n                  <v-col cols=\"2\">C -</v-col>\n                  <v-col\n                    v-for=\"(item, index) in answers[2].text\"\n                    :key=\"index\"\n                    cols=\"2\"\n                    >\n                      <vue-markdown :source=\"item.answerDescription\"/>\n                    </v-col>\n                </v-row>\n                <br />\n\n                <v-row>\n                  <v-col cols=\"2\">D -</v-col>\n                  <v-col\n                    v-for=\"(item, index) in answers[3].text\"\n                    :key=\"index\"\n                    cols=\"2\"\n                    >\n                      <vue-markdown :source=\"item.answerDescription\"/>\n                    </v-col>\n                </v-row>\n              </v-content>\n\n              <v-content v-else>\n                <v-row v-for=\"(item, index) in answers\" :key=\"index\">\n                  <v-col cols=\"1\">{{ letters[index] }} - </v-col>\n                  <v-col>\n                    <vue-markdown :source=\"item.text\"/>\n                  </v-col>\n                </v-row>\n              </v-content>\n            </v-card-text>\n          </v-card>\n        </v-col>\n      </v-row>\n    </v-container>\n  </v-card>\n</template>\n\n<script>\nimport { Editor } from '@toast-ui/vue-editor'\nimport VueMarkdown from 'vue-markdown';\nrequire('vue-markdown');\n\nexport default {\n  components: {\n    Editor,\n    'vue-markdown': VueMarkdown\n  },\n  data() {\n    return {\n      letters: ['A','B','C','D'],\n      images: [],\n      imagesAsURL: \"\",\n      confirmTitle: false,\n      questionDescription: \"\",\n      e1: 1,\n      test: null,\n      columns: null,\n      radios: '',\n      multipleAnswer: false,\n      auxTitle: [],\n      chips: [],\n      items: [],\n      answers: [\n        { text: \"\", ansId: \"radio-1\", value: false },\n        { text: \"\", ansId: \"radio-2\", value: false },\n        { text: \"\", ansId: \"radio-3\", value: false },\n        { text: \"\", ansId: \"radio-4\", value: false }\n      ],\n      id: \"\",\n      subject: \"\",\n      knowledge: \"\",\n      knowledgePWR: \"\",\n      knowledgeBWR: \"\",\n      subjectItems: [\n        \"Teoria do Reator\",\n        \"Termodinâmica\",\n        \"Instrumentação e Controle\",\n        \"Válvulas e Bombas\",\n        \"Eletricidade\",\n        \"Mecânica dos Fluidos\",\n        \"Tratamento Qúimico Refrigerante\",\n        \"Análise Integrada\",\n        \"Instrumentação Nuclear\",\n        \"Física Nuclear\",\n        \"Transferência de Calor\",\n        \"Materiais\"\n      ],\n      number: 1\n    };\n  },\n  computed: {\n    formIsValid() {\n      return (\n        this.id !== \"\" &&\n        this.knowledge !== \"\" &&\n        this.knowledgePWR !== \"\" &&\n        this.knowledgeBWR !== \"\" &&\n        this.subject !== \"\"\n      );\n    }\n  },\n  watch: {\n    e1(val){\n      console.log(val)\n    },\n    number(val) {\n      if (this.number > 1) {\n        this.answers.forEach(element => {\n        let aux = [];\n        for (var i = 0; i < this.number; i++) {\n          aux.push({ title: \"\", answerDescription: \"\" });\n        }\n        element.text = aux;\n      });\n        this.confirmTitle = true;\n      }\n      else {\n        this.answers.forEach(element => {\n          element.text = \"\"\n        })\n        this.confirmTitle = false;\n      }\n    },\n    auxTitle(val) {\n      this.answers.forEach(element => {\n        for (var i = 0; i < this.number; i++) {\n          element.text[i].title = this.auxTitle[i];\n        }\n      });\n    },\n    radios(val) {\n      console.log(\"1\");\n      this.answers.forEach(element => {\n        console.log(\"2\");\n\n        if (element.ansId === val) {\n          console.log(\"3\");\n\n          element.value = true;\n        } else {\n          console.log(\"4\");\n\n          element.value = false;\n        }\n      });\n    }\n  },\n  methods: {\n    decreaseColumns() {\n      if (this.number > 1) this.number--;\n    },\n    increaseColumns() {\n      if (this.number < 5) this.number++;\n    },\n    updateData(variable) {\n      this.questionDescription = variable;\n    },\n    onCreateQuestion() {\n      console.log(\"value: \", this.answers[1].value)\n\n    if ( typeof this.images[0] !== 'undefined') {\n      const imageToUpload = {images: this.images[0]}\n      var URL = this.$store.dispatch(\"uploadImage\", imageToUpload)\n      URL.then(result => {\n        this.imagesAsURL = result\n        console.log(\"Image as URL: \",this.imagesAsURL)\n        const questionData = {\n          id: this.id,\n          subject: this.subject,\n          questionDescription: this.questionDescription,\n          knowledge: this.knowledge,\n          knowledgePWR: this.knowledgePWR,\n          knowledgeBWR: this.knowledgeBWR,\n          answers: this.answers,\n          images: this.imagesAsURL\n        };\n\n        let aux = this.$store.dispatch(\"createQuestion\", questionData);\n        aux.then(()=>{\n          this.setInitialData();\n          this.close();\n        })\n      })\n    }\n\n    else {\n      const questionData = {\n        id: this.id,\n        subject: this.subject,\n        questionDescription: this.questionDescription,\n        knowledge: this.knowledge,\n        knowledgePWR: this.knowledgePWR,\n        knowledgeBWR: this.knowledgeBWR,\n        answers: this.answers,\n        images: \"\"\n      };\n\n      let aux = this.$store.dispatch(\"createQuestion\", questionData);\n      aux.then(()=>{\n        this.setInitialData();\n        this.close();\n      })\n    }\n    },\n    setInitialData() {\n      this.confirmTitle = false;\n      this.questionDescription = \"\";\n      this.e1 = 1;\n      this.test = null;\n      this.columns = null;\n      this.radios = \"aaaa\";\n      this.multipleAnswer = false;\n      this.auxTitle = [];\n      this.chips = [];\n      this.items = [];\n      this.answers = [\n        { text: [], ansId: \"radio-1\", value: false },\n        { text: [], ansId: \"radio-2\", value: false },\n        { text: [], ansId: \"radio-3\", value: false },\n        { text: [], ansId: \"radio-4\", value: false }\n      ];\n      this.id = \"\";\n      this.subject = \"\";\n      this.knowledge = \"\";\n      this.knowledgePWR = \"\";\n      this.knowledgeBWR = \"\";\n      this.subjectItems = [\n        \"Teoria do Reator\",\n        \"Termodinâmica\",\n        \"Instrumentação e Controle\",\n        \"Válvulas e Bombas\",\n        \"Eletricidade\",\n        \"Mecânica dos Fluidos\",\n        \"Tratamento Qúimico Refrigerante\",\n        \"Análise Integrada\",\n        \"Instrumentação Nuclear\",\n        \"Física Nuclear\",\n        \"Transferência de Calor\",\n        \"Materiais\"\n      ];\n      this.number = 0;\n      this.images = [];\n      this.imagesAsBase64 = \"\"\n    },\n    close() {\n      this.setInitialData();\n      this.$emit(\"closeDialogNew\");\n    }\n  }\n};\n</script>\n"],"sourceRoot":"src/components/Questions"}]}