: 100vh;\n    background: url(\"https://www.defesaaereanaval.com.br/wp-content/uploads/2013/05/aramar-em-foto-da-agc3aancia-brasil.jpg\")\n  }\n</style>\n"],"sourceRoot":"src/views"}]}