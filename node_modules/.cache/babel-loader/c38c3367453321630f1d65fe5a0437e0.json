A,IAAA,CAAA,YAAA;AACA,eAAA,GAAA;AACA,OAFA;AAGA,KAPA;AAQA,IAAA,SARA,uBAQA;AACA,WAAA,aAAA;AACA,KAVA;AAWA,IAAA,WAXA,uBAWA,EAXA,EAWA;AAAA;;AACA,MAAA,OAAA,CAAA,GAAA,CAAA,EAAA;AACA,UAAA,GAAA,GAAA,KAAA,MAAA,CAAA,QAAA,CAAA,aAAA,EAAA,EAAA,CAAA;AACA,MAAA,GAAA,CAAA,IAAA,CAAA,YAAA;AACA,QAAA,KAAA,CAAA,mBAAA,GAAA,KAAA;;AACA,QAAA,KAAA,CAAA,UAAA;AACA,OAHA;AAIA;AAlBA;AA1BA,CAAA","sourcesContent":["<template>\n  <div>\n    <v-overlay :value=\"loading\">\n      <v-progress-circular indeterminate size=\"64\"></v-progress-circular>\n    </v-overlay>\n    <v-container>\n      <v-container>\n          <v-container>\n            <v-text-field\n              v-model=\"search\"\n              filled\n              rounded\n              dense\n              append-icon=\"mdi-magnify\"\n              label=\"Search for IQ\"\n              single-line\n              hide-details\n            ></v-text-field>\n          </v-container>\n      </v-container>\n\n      <v-container>\n        <v-card>\n          <v-data-table\n            :headers=\"headers\"\n            :items=\"papers\"\n            :page.sync=\"page\"\n            :items-per-page=\"itemsPerPage\"\n            :search=\"search\"\n            hide-default-footer\n            class=\"elevation-1\"\n            @page-count=\"pageCount = $event\"\n          >\n            <template small v-slot:item.actions=\"{ item }\">\n              <v-icon class=\"mr-2\">mdi-pencil</v-icon>\n              <v-icon @click=\"deletePaperSnackBar = true; deleteSelect = item\">mdi-delete</v-icon>\n            </template>\n          </v-data-table>\n        </v-card>\n      </v-container>\n\n      <v-btn fixed dark fab bottom right color=\"cyan\" @click.stop=\"dialogNewPaper = true\">\n        <v-icon>mdi-plus</v-icon>\n      </v-btn>\n\n      <v-dialog fullscreen hide-overlay transition=\"dialog-bottom-transition\" v-model=\"dialogNewPaper\">\n        <NewPaper @closeDialogNew=\"dialogNewPaper = false\"></NewPaper>\n      </v-dialog>\n\n      <div class=\"text-center pt-2\">\n        <v-pagination v-model=\"page\" :length=\"pageCount\"></v-pagination>\n      </div>\n      <v-snackbar v-model=\"deletePaperSnackBar\" color=\"black\" right top>\n        Você realmente quer deletar esta prova?\n        <v-btn dark color=\"yellow\" text @click=\"deletePaper(deleteSelect.id)\">Ok</v-btn>\n        <v-btn dark color=\"yellow\" text @click=\"deletePaperSnackBar = false\">Cancelar</v-btn>\n      </v-snackbar>\n    </v-container>\n  </div>\n</template>\n\n<script>\nimport NewPaper from './CreatePaper'\n\nexport default {\n  components: {\n    NewPaper\n  },\n  data: () => ({\n    dialogNewPaper: false,\n    headers: [\n      { text: \"Nome\", align: \"left\",  value: \"data.name\" },\n      { text: \"Actions\", value: \"actions\", sortable: false }\n    ],\n    page: 1,\n    pageCount: 15,\n    itemsPerPage: 10,\n    search: \"\",\n    deletePaperSnackBar: false,\n    deleteSelect: \"\",\n  }),\n  computed: {\n    loading () {\n        return this.$store.getters.loading\n        this.$store.dispatch('clearLoading')\n    },\n    papers () {\n      return this.$store.getters.loadedPapers\n    }\n  },\n  methods: {\n    loadPaper() {\n      console.log(\"é mano\")\n      let aux = this.$store.dispatch(\"loadedPapers\");\n      aux.then(()=>{\n        return aux\n      })\n    },\n    setLoader(){\n      this.loadQuestions()\n    },\n    deletePaper(id) {\n      console.log(id);\n      let aux = this.$store.dispatch(\"deletePaper\", id);\n      aux.then(()=>{\n        this.deletePaperSnackBar = false;\n        this.loadPapers();\n      })\n    }\n  }\n}\n</script>\n"],"sourceRoot":"src/components/Documents"}]}