AA;AACA,OAlBA;;AAoBA,eAAA,aAAA,CAAA,IAAA,EAAA;AACA,YAAA,MAAA,GAAA,EAAA;;AACA,aAAA,IAAA,CAAA,GAAA,CAAA,EAAA,CAAA,GAAA,IAAA,CAAA,MAAA,EAAA,CAAA,IAAA,CAAA,EAAA;AACA,UAAA,MAAA,CAAA,IAAA,CAAA;AACA,YAAA,IAAA,EAAA,IAAA,CAAA,CAAA,CADA;AAEA,YAAA,MAAA,EAAA,IAAA,CAAA,CAAA,CAFA;AAGA,YAAA,KAAA,EAAA;AAHA,WAAA;AAKA;;AACA,eAAA,MAAA;AACA;;AAEA,UAAA,OAAA,GAAA,aAAA,CAAA,CAAA,SAAA,EAAA,UAAA,CAAA,CAAA;AACA,MAAA,GAAA,CAAA,KAAA,CAAA,SAAA,GAAA,CAAA,EAAA,MAAA,EAAA,YAAA,CAAA,KAAA,WAAA,CAAA,MAAA,CAAA,EAAA,OAAA;AACA,MAAA,GAAA,CAAA,IAAA,CAAA,UAAA;AACA;AA7HA;AAlBA,CAAA","sourcesContent":["<template>\n  <v-card>\n    <v-btn @click=\"generatePdf()\">Gerar PDF</v-btn>\n    {{currentTest}}\n  </v-card>\n</template>\n\n<script>\nimport jsPDF from \"jspdf\";\nimport html2canvas from \"html2canvas\";\nimport fontFile from \"@/assets/ARIALUNI.TTF\";\n\nexport default {\n  props: [\"test\"],\n  data() {\n    return {\n      letters: [\"A\", \"B\", \"C\", \"D\"]\n    };\n  },\n  computed: {\n    currentTest() {\n      let aux = [];\n\n      this.test.data.PERGUNTAS.forEach(element =>\n        aux.push(this.$store.getters.findQuestionById(element))\n      );\n\n      return aux;\n    }\n  },\n  methods: {\n    generatePdf() {\n      var pageWidth = 203.2,\n        lineHeight = 30.48,\n        margin = 25.4,\n        maxLineWidth = pageWidth - margin * 2,\n        fontSize = 12;\n\n      var doc = new jsPDF()\n\n      doc.setFontSize(fontSize)\n\n      var fontInBase64 = \"\",\n        fileName = \"\",\n        reader = new FileReader();\n\n      this.currentTest.forEach( element => {\n        if ( typeof element.data.IMAGENS === 'undefined' || element.data.IMAGENS === \"\" ){\n          let texttohtml = `\nASSUNTO: ${element.data.DISCIPLINA}\nCONHECIMENTO: ${element.data.CONHECIMENTO} [${element.data.RELEVANCIA_OR}/${element.data.RELEVANCIA_OSR}]\nIQ: ${element.id}\n\n      ${element.data.PERGUNTA}\n\nA - ${element.data.RESPOSTAS[0].text}\n\nB - ${element.data.RESPOSTAS[1].text}\n\nC - ${element.data.RESPOSTAS[2].text}\n\nD - ${element.data.RESPOSTAS[3].text}\n          `\n          let textLines = doc.splitTextToSize(texttohtml,maxLineWidth)\n          doc.text(textLines, margin, margin)\n\n          doc.addPage( \"a4\", \"p\" )\n        }\n\n        else {\n          let texttohtml = `\nASSUNTO: ${element.data.DISCIPLINA}\nCONHECIMENTO: ${element.data.CONHECIMENTO} [${element.data.RELEVANCIA_OR}/${element.data.RELEVANCIA_OSR}]\nIQ: ${element.id}\n\n      ${element.data.PERGUNTA}\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n      \n\nA - ${element.data.RESPOSTAS[0].text}\n\nB - ${element.data.RESPOSTAS[1].text}\n\nC - ${element.data.RESPOSTAS[2].text}\n\nD - ${element.data.RESPOSTAS[3].text}\n          `\n          let textLines = doc.splitTextToSize(texttohtml,maxLineWidth)\n          doc.text(textLines, margin, margin)\n\n          doc.addImage(element.data.IMAGENS, \"JPEG\", pageWidth/4, 100, 76.2, 76.2)\n\n          doc.addPage( \"a4\", \"p\" )\n        }\n      })\n\n    var letters = [\"A\", \"B\", \"C\", \"D\"];\n\n    var generateData = (amount) => {\n      var result = []\n      var data = {\n        QUESTÃO: \"\",\n        RESPOSTA: \"\"\n      }\n\n      for(var i = 0; i < amount; i++){\n        data.QUESTÃO = `${i+1}`\n\n        for(var j = 0; j < 4; j++ ){\n          if ( this.currentTest[i].data.RESPOSTAS[j].value === true ) {\n            data.RESPOSTA = letters[j]\n          }\n        }\n        result.push(Object.assign({}, data))\n      }\n      return result\n    };\n\n    function createHeaders(keys) {\n      var result = [];\n      for (var i = 0; i < keys.length; i += 1) {\n        result.push({\n          name: keys[i],\n          prompt: keys[i],\n          width: 40\n        });\n      }\n      return result;\n    }\n\n      var headers = createHeaders([\"QUESTÃO\", \"RESPOSTA\"]);\n      doc.table(pageWidth/4, margin, generateData(this.currentTest.length), headers);\n      doc.save(\"test.pdf\")\n    }\n  }\n};\n</script>\n"],"sourceRoot":"src/components/Tests"}]}