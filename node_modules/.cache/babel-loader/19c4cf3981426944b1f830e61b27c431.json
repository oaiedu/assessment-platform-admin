{"remainingRequest":"/home/octavio/Projects/vue/aramar/node_modules/babel-loader/lib/index.js!/home/octavio/Projects/vue/aramar/node_modules/vuetify-loader/lib/loader.js??ref--17-0!/home/octavio/Projects/vue/aramar/node_modules/cache-loader/dist/cjs.js??ref--0-0!/home/octavio/Projects/vue/aramar/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/octavio/Projects/vue/aramar/src/components/Questions/PrintQuestion/Body.vue?vue&type=script&lang=js&","dependencies":[{"path":"/home/octavio/Projects/vue/aramar/src/components/Questions/PrintQuestion/Body.vue","mtime":1594004071280},{"path":"/home/octavio/Projects/vue/aramar/node_modules/cache-loader/dist/cjs.js","mtime":1590160436635},{"path":"/home/octavio/Projects/vue/aramar/node_modules/babel-loader/lib/index.js","mtime":499162500000},{"path":"/home/octavio/Projects/vue/aramar/node_modules/vuetify-loader/lib/loader.js","mtime":1574476662000},{"path":"/home/octavio/Projects/vue/aramar/node_modules/cache-loader/dist/cjs.js","mtime":1590160436635},{"path":"/home/octavio/Projects/vue/aramar/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Body.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAgIA,OAAA,WAAA,MAAA,cAAA;;AACA,OAAA,CAAA,cAAA,CAAA;;AAEA,eAAA;AACA,EAAA,KAAA,EAAA,CAAA,UAAA,CADA;AAEA,EAAA,UAAA,EAAA;AACA,oBAAA;AADA,GAFA;AAKA,EAAA,IALA,kBAKA;AACA,WAAA;AACA,MAAA,OAAA,EAAA,CAAA,GAAA,EAAA,GAAA,EAAA,GAAA,EAAA,GAAA;AADA,KAAA;AAGA,GATA;AAUA,EAAA,OAAA,EAAA;AACA,IAAA,IADA,kBACA;AACA,WAAA,KAAA,CAAA,kBAAA;AACA,KAHA;AAIA,IAAA,OAJA,qBAIA;AACA,MAAA,MAAA,CAAA,KAAA;AACA,KANA;AAOA,IAAA,YAPA,wBAOA,GAPA,EAOA;AACA,UAAA,OAAA,GAAA,IAAA,WAAA,IAAA,GAAA,IAAA,EAAA,EAAA,OAAA,KAAA,CAAA,KACA,OAAA,IAAA;AACA,KAVA;AAWA,IAAA,KAXA,mBAWA;AACA,WAAA,KAAA,CAAA,kBAAA;AACA;AAbA;AAVA,CAAA","sourcesContent":["<template>\n  <v-card>\n    <v-container>\n      <v-row justify=\"center\">\n        <div class=\"print\">\n          <link rel=\"stylesheet\" href=\"https://unpkg.com/katex@0.6.0/dist/katex.min.css\" />\n          <div class=\"question-page\">\n            DISCIPLINA: {{ question.data.DISCIPLINA }}\n            <br />\n            CONHECIMENTO: {{ question.data.CONHECIMENTO }} [ {{ question.data.RELEVANCIA_OR }} / {{ question.data.RELEVANCIA_OSR }} ]\n            <br />\n            IQ: {{ question.id }}\n            <br />\n\n            <br />\n            <vue-markdown :source=\"question.data.PERGUNTA\" />\n            <br />\n\n            <br />\n\n            <div class=\"img-container\" v-if=\"confirmImage(question.data.IMAGENS)\">\n              <v-content v-if=\"question.data.TAMANHO_IMAGEM === '1x'\">\n                <img :src=\"question.data.IMAGENS\" style=\"max-height: 40vh; max-width: 40vw\" />\n              </v-content>\n\n              <v-content v-if=\"question.data.TAMANHO_IMAGEM === '2x'\">\n                <img :src=\"question.data.IMAGENS\" style=\"max-height: 50vh; max-width: 50vw\" />\n              </v-content>\n\n              <v-content v-if=\"question.data.TAMANHO_IMAGEM === '3x'\">\n                <img :src=\"question.data.IMAGENS\" style=\"max-height: 60vh; max-width: 60vw\" />\n              </v-content>\n\n              <v-content v-if=\"question.data.TAMANHO_IMAGEM === undefined\">\n                <img :src=\"question.data.IMAGENS\" style=\"max-height: 50vh; max-width: 50vw\" />\n              </v-content>\n            </div>\n\n            <v-content v-if=\"typeof question.data.RESPOSTAS[0].text !== 'string'\">\n              <v-row>\n                <v-col cols=\"2\"></v-col>\n                <v-col\n                  v-for=\"(item, index) in question.data.RESPOSTAS[0].text\"\n                  :key=\"index\"\n                  cols=\"2\"\n                >\n                  <vue-markdown :source=\"item.title\" />\n                </v-col>\n              </v-row>\n\n              <v-row>\n                <v-col cols=\"2\">A -</v-col>\n                <v-col\n                  v-for=\"(item, index) in question.data.RESPOSTAS[0].text\"\n                  :key=\"index\"\n                  cols=\"2\"\n                >\n                  <vue-markdown :source=\"item.answerDescription\" />\n                </v-col>\n              </v-row>\n\n              <v-row>\n                <v-col cols=\"2\">B -</v-col>\n                <v-col\n                  v-for=\"(item, index) in question.data.RESPOSTAS[1].text\"\n                  :key=\"index\"\n                  cols=\"2\"\n                >\n                  <vue-markdown :source=\"item.answerDescription\" />\n                </v-col>\n              </v-row>\n\n              <v-row>\n                <v-col cols=\"2\">C -</v-col>\n                <v-col\n                  v-for=\"(item, index) in question.data.RESPOSTAS[2].text\"\n                  :key=\"index\"\n                  cols=\"2\"\n                >\n                  <vue-markdown :source=\"item.answerDescription\" />\n                </v-col>\n              </v-row>\n\n              <v-row>\n                <v-col cols=\"2\">D -</v-col>\n                <v-col\n                  v-for=\"(item, index) in question.data.RESPOSTAS[3].text\"\n                  :key=\"index\"\n                  cols=\"2\"\n                >\n                  <vue-markdown :source=\"item.answerDescription\" />\n                </v-col>\n              </v-row>\n            </v-content>\n\n            <v-content v-else>\n              <v-row v-for=\"(item, index) in question.data.RESPOSTAS\" :key=\"index\">\n                <v-col cols=\"2\">{{ letters[index] }} -</v-col>\n                <v-col>\n                  <vue-markdown :source=\"item.text\" />\n                </v-col>\n              </v-row>\n            </v-content>\n\n            <v-btn\n              class=\"buttonIsHidden\"\n              fixed\n              dark\n              fab\n              bottom\n              right\n              color=\"red\"\n              @click=\"toPrint()\"\n            >\n              <v-icon>mdi-file-outline</v-icon>\n            </v-btn>\n\n            <v-btn fixed fab bottom left class=\"buttonIsHidden\" @click=\"back()\">\n              <v-icon>mdi-arrow-left</v-icon>\n            </v-btn>\n          </div>\n        </div>\n      </v-row>\n    </v-container>\n  </v-card>\n</template>\n\n<script>\nimport VueMarkdown from \"vue-markdown\";\nrequire(\"vue-markdown\");\n\nexport default {\n  props: [\"question\"],\n  components: {\n    \"vue-markdown\": VueMarkdown\n  },\n  data() {\n    return {\n      letters: [\"A\", \"B\", \"C\", \"D\"]\n    };\n  },\n  methods: {\n    back() {\n      this.$emit(\"closeDialogPrint\");\n    },\n    toPrint() {\n      window.print();\n    },\n    confirmImage(val) {\n      if (typeof val == \"undefined\" || val == \"\") return false;\n      else return true;\n    },\n    close() {\n      this.$emit(\"closeDialogPrint\");\n    }\n  }\n};\n</script>\n\n<style>\n.img-container {\n  text-align: center;\n}\n@media print {\n  header {\n    display: none !important;\n  }\n  .print {\n    background-color: white;\n    height: 100%;\n    width: 100%;\n    position: fixed;\n    display: block;\n    top: 0;\n    left: 0;\n    margin: 0;\n    padding: 15px;\n    font-size: 14px;\n    line-height: 18px;\n  }\n  @page {\n    margin-top: 2cm;\n    margin-bottom: 2cm;\n    margin-left: 2cm;\n    margin-right: 2cm;\n  }\n  .question-page {\n    page-break-after: always;\n  }\n\n  .buttonIsHidden {\n    visibility: hidden;\n  }\n\n  .img-container {\n    text-align: center !important;\n  }\n\n  p {\n    page-break-inside: avoid;\n  }\n}\n</style>\n"],"sourceRoot":"src/components/Questions/PrintQuestion"}]}