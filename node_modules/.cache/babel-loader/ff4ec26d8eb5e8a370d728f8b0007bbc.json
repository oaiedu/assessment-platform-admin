A,MAAA,EAAA,KAAA;AAAA,OAAA;AACA,MAAA,OAAA,CAAA,GAAA,CAAA,YAAA,EAAA,aAAA;AACA,UAAA,GAAA,GAAA,KAAA,MAAA,CAAA,QAAA,CAAA,cAAA,EAAA,aAAA,CAAA;AACA,MAAA,GAAA,CAAA,IAAA,CAAA,UAAA,MAAA,EAAA;AACA,QAAA,KAAA,CAAA,WAAA,GAAA,MAAA;AACA,QAAA,KAAA,CAAA,QAAA,GAAA,KAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,gBAAA,EAAA,KAAA,CAAA,WAAA;AACA,OAJA;AAKA,KAhBA;AAiBA,IAAA,MAjBA,oBAiBA;AACA,UAAA,aAAA,GAAA;AACA,QAAA,IAAA,EAAA,KAAA,QADA;AAEA,QAAA,aAAA,EAAA,KAAA;AAFA,OAAA;AAIA,WAAA,MAAA,CAAA,QAAA,CAAA,YAAA,EAAA,aAAA;AACA,WAAA,OAAA,CAAA,IAAA,CAAA,GAAA;AACA;AAxBA;AA3BA,CAAA","sourcesContent":["<template>\n  <v-row justify=\"center\">\n    <v-col cols=\"12\" sm=\"10\" md=\"8\" lg=\"6\">\n      <v-card ref=\"form\">\n        <v-card-text>\n          <p style=\"visibility: hidden; max-height: 1px\">{{user}}</p>\n          <div class=\"text-center\">\n            <v-row>\n              <v-col>\n                <v-row justify=\"center\">\n                  <v-file-input id=\"fileUpload\" @change=\"sendImage()\" v-model=\"avatarImage\" style=\"visibility: hidden; max-height: 1px\" />\n                </v-row>\n                <v-row justify=\"center\">\n                  <v-avatar size=\"100\" @click=\"addImage()\" clickable>\n                    <img\n                      src=\"https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_960_720.png\"\n                      v-if=\" imagesAsURL === null \"\n                    />\n                    <img :src=\"imagesAsURL\" v-else />\n                  </v-avatar>\n                </v-row>\n              </v-col>\n            </v-row>\n          </div>\n        </v-card-text>\n\n        <v-card-text>\n          <v-text-field\n            ref=\"nickName\"\n            v-model=\"nickName\"\n            :rules=\"[() => !!nickName || 'This field is required']\"\n            label=\"Nome completo\"\n            placeholder=\"Fill with firebase\"\n            required\n          ></v-text-field>\n          <transition\n            name=\"fade\"\n            mode=\"out-in\"\n          >\n            <v-content v-if=\"showChangePassword === true\">\n              <v-form @submit.prevent=\"onChangePassword\">\n                <v-text-field\n                  label=\"New Password\"\n                  v-model=\"editedPassword\"\n                  type=\"password\"\n                ></v-text-field>\n                <v-text-field\n                  label=\"Confirm New Password\"\n                  v-model=\"confirmNewPassword\"\n                  type=\"password\"\n                  :rules=\"[comparePassword]\"\n                ></v-text-field>\n                <v-text-field\n                  label=\"Old Password\"\n                  type=\"password\"\n                  v-model=\"confirmOldPassword\"\n                ></v-text-field>\n              </v-form>\n            </v-content>\n          </transition>\n          <!-- <v-text-field\n            ref=\"name\"\n            v-model=\"nickName\"\n            :rules=\"[() => !!name || 'This field is required']\"\n            :error-messages=\"errorMessages\"\n            label=\"Nome completo\"\n            placeholder=\"Fill with firebase\"\n            required\n          ></v-text-field> -->\n        </v-card-text>\n\n        <v-divider class=\"mt-12\"></v-divider>\n\n        <v-card-actions>\n          <v-btn\n            color=\"primary\"\n            text\n            @click=\"cancel()\"\n          >\n            Cancelar\n          </v-btn>\n\n          <v-spacer/>\n\n          <v-btn\n            color=\"primary\"\n            text\n            @click=\"submit()\"\n          >\n            Salvar Alterações\n          </v-btn>\n        </v-card-actions>\n      </v-card>\n    </v-col>\n  </v-row>\n</template>\n\n<script>\nexport default {\n  data: () => ({\n    avatarImage: [],\n    nickName: null,\n    hasImage: false,\n    imagesAsURL: null,\n    editedPassword: \"\",\n    confirmNewPassword: \"\",\n    confirmOldPassword: \"\",\n    showChangePassword: false\n  }),\n  computed: {\n    comparePassword () {\n      return this.editedPassword !== this.confirmNewPassword ? 'Passwords do not match' : ''\n    },\n    user() {\n      var val = this.$store.getters.userInfo\n\n      if ( val.name !== \"\")\n        this.nickName = val.name\n\n      if ( val.profileImages !== \"\")\n        this.imagesAsURL = val.profileImages\n\n      return val;\n    },\n  },\n  methods: {\n    cancel(){\n      this.$router.push('/');\n    },\n    addImage() {\n      document.getElementById(\"fileUpload\").click();\n    },\n    sendImage() {\n      const imageToUpload = { images: this.avatarImage };\n      console.log(\"sla mano: \", imageToUpload);\n      var URL = this.$store.dispatch(\"uploadAvatar\", imageToUpload);\n      URL.then(result => {\n        this.imagesAsURL = result;\n        this.hasImage = false;\n        console.log(\"Image as URL: \", this.imagesAsURL);\n      });\n    },\n    submit() {\n      var updateChanges = {\n        name: this.nickName,\n        profileImages: this.imagesAsURL\n      }\n      this.$store.dispatch(\"updateUser\", updateChanges)\n      this.$router.push(\"/\")\n    }\n  }\n};\n</script>\n\n<style>\n.fade-enter-active, .fade-leave-active {\n  transition: opacity .5s;\n}\n.fade-enter, .fade-leave-to{\n  opacity: 0;\n}\n\n</style>\n"],"sourceRoot":"src/components/User"}]}