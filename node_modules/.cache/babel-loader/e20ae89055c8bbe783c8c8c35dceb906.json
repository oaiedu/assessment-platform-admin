aAAA,EAAA,aAAA,CAAA;AACA,QAAA,GAAA,CAAA,IAAA,CAAA,UAAA,MAAA,EAAA;AACA,UAAA,KAAA,CAAA,UAAA,GAAA,MAAA;AACA,UAAA,OAAA,CAAA,GAAA,CAAA,gBAAA,EAAA,KAAA,CAAA,UAAA;AACA,cAAA,SAAA,GAAA;AACA,YAAA,SAAA,EAAA,KAAA,CAAA,SADA;AAEA,YAAA,gBAAA,EAAA,KAAA,CAAA,gBAFA;AAGA,YAAA,UAAA,EAAA,KAAA,CAAA;AAHA,WAAA;;AAMA,cAAA,GAAA,GAAA,KAAA,CAAA,MAAA,CAAA,QAAA,CAAA,aAAA,EAAA,SAAA,CAAA;;AACA,UAAA,GAAA,CAAA,IAAA,CAAA,YAAA;AACA,YAAA,KAAA,CAAA,KAAA,CAAA,MAAA;;AACA,YAAA,KAAA,CAAA,KAAA;AACA,WAHA;AAIA,SAdA;AAeA,OAlBA,MAoBA;AACA,YAAA,SAAA,GAAA;AACA,UAAA,SAAA,EAAA,KAAA,SADA;AAEA,UAAA,gBAAA,EAAA,KAAA,gBAFA;AAGA,UAAA,UAAA,EAAA,KAAA;AAHA,SAAA;AAMA,YAAA,GAAA,GAAA,KAAA,MAAA,CAAA,QAAA,CAAA,aAAA,EAAA,SAAA,CAAA;AACA,QAAA,GAAA,CAAA,IAAA,CAAA,YAAA;AACA,UAAA,KAAA,CAAA,KAAA,CAAA,MAAA;;AACA,UAAA,KAAA,CAAA,KAAA;AACA,SAHA;AAIA;AACA;AArDA;AARA,CAAA","sourcesContent":["<template>\n  <v-card>\n    <v-form ref=\"formRef\" @submit.prevent=\"onCreatePaper()\">\n      <v-toolbar dark color=\"primary\">\n        <v-btn icon dark @click=\"close()\">\n          <v-icon>mdi-close</v-icon>\n        </v-btn>\n        <v-spacer></v-spacer>\n          <v-btn dark text type=\"submit\">Criar Documento</v-btn>\n        </v-toolbar-items>\n      </v-toolbar>\n      <v-container fluid>\n        <v-row>\n          <v-col>\n            <v-row>\n              <v-col>\n                <h1>Formulário</h1>\n              </v-col>\n            </v-row>\n            <v-row>\n              <v-col cols=\"12\">\n                <v-card>\n                  <v-container>\n                    <v-row>\n                      <v-col>\n                        <v-text-field\n                          solo\n                          flat\n                          filled\n                          outlined\n                          dense\n                          label=\"Paper name\"\n                          v-model=\"paperName\"\n                          required\n                        ></v-text-field>\n                      </v-col>\n                    </v-row>\n                    <v-row>\n                      <v-col>\n                          <v-file-input\n                            chips\n                            multiple\n                            dense\n                            label=\"Imagem\"\n                            v-model=\"images\"\n                          />\n                      </v-col>\n                    </v-row>\n                    <v-row>\n                      <v-col>\n                        <Combined @inputData=\"updateData\"></Combined>\n                      </v-col>\n                    </v-row>\n                  </v-container>\n                </v-card>\n              </v-col>\n            </v-row>\n          </v-col>\n          <v-col>\n            <v-row>\n              <v-col>\n                <h1>Preview</h1>\n              </v-col>\n            </v-row>\n\n            <v-row>\n              <v-col cols=\"12\">\n                <v-card>\n                  <v-card-title>{{paperName}}</v-card-title>\n                  <v-card-text>{{paperDescription}}</v-card-text>\n                </v-card>\n              </v-col>\n            </v-row>\n          </v-col>\n        </v-row>\n      </v-container>\n    </v-form>\n  </v-card>\n</template>\n\n<script>\nexport default {\n  data: () => ({\n    paperDescription: null,\n    paperName: null,\n    images: [],\n    paperImage: \"\"\n  }),\n\n  methods: {\n    updateData(variable) {\n      this.paperDescription = variable;\n    },\n    close() {\n      this.setInitialData();\n      this.$emit(\"closeDialogNew\");\n    },\n    setInitialData() {\n      this.paperDescription = null,\n      this.paperName = null,\n      this.paperImage = \"\",\n      this.image = []\n    },\n    onCreatePaper() {\n      if((this.paperName === \"\" && this.paperDescription === \"\") || (this.paperName === \"\" && typeof this.images[0] === 'undefined')){\n        console.log(\"nop\");\n        return\n      }\n\n      if ( typeof this.images[0] !== 'undefined') {\n        const imageToUpload = {images: this.images[0]}\n        var URL = this.$store.dispatch(\"uploadImage\", imageToUpload)\n        URL.then(result => {\n          this.paperImage = result\n          console.log(\"Image as URL: \",this.paperImage)\n          const paperData = {\n            paperName: this.paperName,\n            paperDescription: this.paperDescription,\n            paperImage: this.paperImage\n          };\n\n          let aux = this.$store.dispatch(\"createPaper\", paperData);\n          aux.then(()=>{\n            this.$emit(\"load\");\n            this.close();\n          })\n        })\n      }\n\n      else {\n        const paperData = {\n          paperName: this.paperName,\n          paperDescription: this.paperDescription,\n          paperImage: this.paperImage\n        };\n\n        let aux = this.$store.dispatch(\"createPaper\", paperData);\n        aux.then(()=>{\n          this.$emit(\"load\");\n          this.close();\n        })\n      }\n    }\n  }\n}\n</script>\n"],"sourceRoot":"src/components/Documents"}]}