A,UAAA,KAAA,EAAA,sBAFA;AAGA,UAAA,IAAA,EAAA;AAHA,SAhBA,EAqBA;AACA,UAAA,IAAA,EAAA,aADA;AAEA,UAAA,KAAA,EAAA,QAFA;AAGA,UAAA,IAAA,EAAA;AAHA,SArBA,CAAA;AA2BA;;AACA,aAAA,WAAA;AACA,KAvCA;AAwCA,IAAA,SAxCA,uBAwCA;AACA,UAAA,SAAA,GAAA,EAAA;;AAEA,UAAA,KAAA,mBAAA,EAAA,EAAA;AACA,QAAA,SAAA,GAAA,EAAA;AAEA;;AACA,aAAA,SAAA;AACA;AAhDA,GARA;AA0DA,EAAA,OAAA,EAAA;AACA,IAAA,mBADA,iCACA;AACA,aACA,KAAA,MAAA,CAAA,OAAA,CAAA,IAAA,KAAA,IAAA,IACA,KAAA,MAAA,CAAA,OAAA,CAAA,IAAA,KAAA,SAFA;AAIA,KANA;AAOA,IAAA,QAPA,sBAOA;AACA,WAAA,MAAA,CAAA,QAAA,CAAA,QAAA;AACA,WAAA,OAAA,CAAA,IAAA,CAAA,GAAA;AACA;AAVA;AA1DA,CAAA","sourcesContent":["<template>\n  <v-app>\n    <v-navigation-drawer v-model=\"drawer\" absolute temporary>\n      <v-content v-if=\"authUser !== null\">\n        <v-list>\n          <v-list-item class=\"px-2\">\n            <v-list-item-avatar>\n              <img\n                src=\"https://cdn.pixabay.com/photo/2015/10/05/22/37/blank-profile-picture-973460_960_720.png\"\n                v-if=\" user.profileImages === '' || user.profileImages === null \"\n              />\n              <img :src=\"user.profileImages\" v-else />\n            </v-list-item-avatar>\n          </v-list-item>\n\n          <v-list-item link>\n            <v-list-item-content>\n              <v-list-item-title class=\"title\">{{user.name}}</v-list-item-title>\n              <v-list-item-subtitle>{{user.email}}</v-list-item-subtitle>\n            </v-list-item-content>\n          </v-list-item>\n        </v-list>\n\n        <v-divider></v-divider>\n\n\n        <v-list nav dense>\n          <v-list-item v-for=\"item in drawerItems\" :key=\"item.title\" :to=\"item.link\">\n            <v-list-item-icon>\n              <v-icon>{{ item.icon }}</v-icon>\n            </v-list-item-icon>\n\n            <v-list-item-content>\n              <v-list-item-title>{{ item.title }}</v-list-item-title>\n            </v-list-item-content>\n          </v-list-item>\n        </v-list>\n      </v-content>\n    </v-navigation-drawer>\n    <v-app-bar app color=\"light-blue darken-4\" dark dense absolute>\n      <v-app-bar-nav-icon @click.stop=\"drawer = !drawer\" v-if=\"authUser !== null\"></v-app-bar-nav-icon>\n      <v-toolbar-title>PWR Quiz Generator</v-toolbar-title>\n      <v-spacer></v-spacer>\n      <v-btn text v-for=\"item in menuItems\" :key=\"item.title\" :to=\"item.link\">\n        <v-icon left>{{ item.icon }}</v-icon>\n        {{ item.title }}\n      </v-btn>\n      <v-btn v-if=\"userIsAuthenticated()\" text @click=\"onLogout\">\n        <v-icon left>mdi-logout-variant</v-icon>Log Out\n      </v-btn>\n    </v-app-bar>\n\n    <v-content>\n      <Error/>\n      <router-view></router-view>\n    </v-content>\n  </v-app>\n</template>\n\n<script>\nimport Error from '../components/Error'\n\n\nexport default {\n  props: {\n    source: String\n  },\n  components: {Error},\n  data: () => ({\n    drawer: null,\n  }),\n  computed: {\n    authUser() {\n      return this.$store.getters.user\n    },\n    user(){\n      return this.$store.getters.userInfo\n    },\n    drawerItems() {\n      let drawerItems = [];\n      if (this.userIsAuthenticated()) {\n        drawerItems = [\n        {\n          icon: \"mdi-home\",\n          title: \"Página Inicial\",\n          link: \"/\"\n        },\n          {\n            icon: \"mdi-file-question-outline\",\n            title: \"Gerenciar Questões\",\n            link: \"/questions\"\n          },\n          {\n            icon: \"mdi-file-multiple-outline\",\n            title: \"Gerenciar provas\",\n            link: \"/tests\"\n          },\n          {\n            icon: \"mdi-file-document\",\n            title: \"Gerenciar Documentos\",\n            link: \"/createpaper\"\n          },\n          {\n            icon: \"mdi-account\",\n            title: \"Perfil\",\n            link: \"/profile\"\n          }\n        ];\n      }\n      return drawerItems;\n    },\n    menuItems() {\n      let menuItems = [\n      ];\n      if (this.userIsAuthenticated()) {\n        menuItems = [\n        ];\n      }\n      return menuItems;\n    }\n  },\n  methods: {\n    userIsAuthenticated() {\n      return (\n        this.$store.getters.user !== null &&\n        this.$store.getters.user !== undefined\n      );\n    },\n    onLogout() {\n      this.$store.dispatch(\"logout\");\n      this.$router.push(\"/\");\n    }\n  }\n};\n</script>\n"],"sourceRoot":"src/layouts"}]}